{
    "name": "meteor-impact",
    "displayName": "Meteor Impact",
    "description": "Full-impact language tooling for Meteor and Blaze: TypeScript-aware indexing, completions, go-to-definition, rename, diagnostics, refactorings and template scaffolding.",
    "version": "2.0.0",
    "private": "true",
    "publisher": "gabdsg",
    "license": "MIT",
    "contributors": [
        {
            "name": "Matheus Castro"
        },
        {
            "name": "Renan Castro"
        }
    ],
    "icon": "images/icon.png",
    "engines": {
        "vscode": "^1.66.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gabdsg/vscode-meteor-toolbox.git"
    },
    "bugs": {
        "url": "https://github.com/gabdsg/vscode-meteor-toolbox/issues"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "meteor",
        "blaze",
        "spacebars",
        "intelisense",
        "atmosphere",
        "packages"
    ],
    "activationEvents": [
        "workspaceContains:.meteor/release",
        "onLanguage:spacebars",
        "onLanguage:javascript"
    ],
    "contributes": {
        "configuration": [
            {
                "id": "meteorImpact",
                "title": "Settings for Meteor Impact extension",
                "order": 2,
                "properties": {
                    "conf.settingsEditor.meteorImpact": {
                        "type": "object",
                        "order": 2,
                        "description": "Meteor Impact options.",
                        "properties": {
                            "auto": {
                                "type": "boolean",
                                "description": "Should we watch the packages folder and automatically update jsconfig.js"
                            },
                            "port": {
                                "type": "string",
                                "description": "Port to use when building run/debug options."
                            },
                            "additionalArgs": {
                                "type": "string",
                                "description": "Additional arguments to pass to meteor run/debug commands."
                            },
                            "meteorPackageDirs": {
                                "type": "string",
                                "description": "Colon-delimited list of local package directories to look in, besides the default packages folder. The path should be relative to the current workspace."
                            },
                            "ignoreDirsOnIndexing": {
                                "type": "string",
                                "description": "Colon-delimited list of directories to not index on the language server. The path should be relative to the current workspace."
                            }
                        },
                        "additionalProperties": false,
                        "default": {
                            "auto": true,
                            "port": "3000",
                            "additionalArgs": null,
                            "meteorPackageDirs": null,
                            "ignoreDirsOnIndexing": null
                        }
                    }
                }
            }
        ],
        "commands": [
            {
                "category": "Configuration",
                "command": "meteorImpact.toggleAutoRunPackagesWatcher",
                "title": "Toggle Meteor Impact Auto Run"
            },
            {
                "category": "Commands",
                "command": "meteorImpact.runOnce",
                "title": "Run Meteor Impact set up manually"
            },
            {
                "category": "Commands",
                "command": "meteorImpact.clearMeteorBuildCache",
                "title": "Run clear meteor build cache"
            },
            {
                "category": "Commands",
                "command": "meteorImpact.regenerateLaunchJson",
                "title": "Re-create Meteor Impact run/debug options"
            },
            {
                "category": "Commands",
                "command": "meteorImpact.createTemplate",
                "title": "Create Blaze Template"
            },
            {
                "category": "Commands",
                "command": "meteorImpact.goToCounterpart",
                "title": "Go to Template Counterpart (html/code/style)"
            },
            {
                "category": "Commands",
                "command": "meteorImpact.enableTemplateFileNesting",
                "title": "Nest Template Files Under Code-Behind"
            },
            {
                "category": "Commands",
                "command": "meteorImpact.generateSettingsTypes",
                "title": "Generate Meteor.settings Types"
            },
            {
                "category": "Commands",
                "command": "meteorImpact.renameTemplate",
                "title": "Rename Blaze Template"
            }
        ],
        "keybindings": [
            {
                "command": "meteorImpact.goToCounterpart",
                "key": "alt+o",
                "when": "editorTextFocus && meteorImpact.isMeteorProject"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "meteorImpact.createTemplate",
                    "when": "meteorImpact.isMeteorProject && explorerResourceIsFolder",
                    "group": "2_workspace"
                },
                {
                    "command": "meteorImpact.renameTemplate",
                    "when": "meteorImpact.isMeteorProject && explorerResourceIsFolder",
                    "group": "2_workspace"
                }
            ],
            "commandPalette": [
                {
                    "command": "meteorImpact.createTemplate",
                    "when": "meteorImpact.isMeteorProject"
                }
            ]
        },
        "languages": [
            {
                "id": "spacebars",
                "aliases": [
                    "Spacebars",
                    "spacebars"
                ],
                "extensions": [
                    ".html"
                ],
                "icon": {
                    "light": "./images/blaze-icon.png",
                    "dark": "./images/blaze-icon.png"
                },
                "configuration": "./spacebars/language-configuration.json"
            }
        ],
        "snippets": [
            {
                "language": "spacebars",
                "path": "./snippets/spacebars.json"
            },
            {
                "language": "javascript",
                "path": "./snippets/meteor.json"
            },
            {
                "language": "typescript",
                "path": "./snippets/meteor.json"
            }
        ],
        "grammars": [
            {
                "language": "spacebars",
                "scopeName": "text.html.spacebars",
                "path": "./spacebars/syntaxes/spacebars.tmLanguage.json"
            }
        ],
        "configurationDefaults": {
            "emmet.includeLanguages": {
                "spacebars": "html"
            }
        },
        "typescriptServerPlugins": [
            {
                "name": "typescript-meteor-impact-plugin",
                "enableForWorkspaceTypeScriptVersions": true
            }
        ]
    },
    "main": "./extension.js",
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "node ./test/runTest.js",
        "test:server": "mocha \"test/server/**/*.test.js\"",
        "postinstall": "cd server && npm install && cd ../.."
    },
    "devDependencies": {
        "@types/glob": "^7.2.0",
        "@types/mocha": "^9.1.1",
        "@types/node": "14.x",
        "@types/vscode": "^1.66.0",
        "@vscode/test-electron": "^2.1.3",
        "eslint": "^8.14.0",
        "glob": "^8.0.1",
        "mocha": "^9.2.2",
        "typescript": "^4.8.4"
    },
    "dependencies": {
        "deepmerge": "^4.2.2",
        "json5": "^2.2.1",
        "lodash": "^4.17.21",
        "vscode-languageclient": "8.0.2",
        "typescript-meteor-impact-plugin": "./typescript-meteor-impact-plugin"
    }
}
